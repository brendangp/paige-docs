{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "paige",
  "description": "Build AI-powered WhatsApp bots with interactive flows, automated conversations, and a built-in database — no backend required.",
  "colors": {
    "primary": "#81D741",
    "light": "#cfeabb",
    "dark": "#81D741"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/green-pages-logo.png",
    "dark": "/logo/green-pages-logo.png"
  },
  "fonts": {
    "family": "Geist"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Introduction",
        "icon": "rocket",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "index"
            ]
          }
        ]
      },
      {
        "tab": "Features",
        "icon": "sparkles",
        "groups": [
          {
            "group": "Core concepts",
            "pages": [
              "concepts/projects",
              "concepts/bot-code",
              "concepts/flows",
              "concepts/database",
              "concepts/conversations"
            ]
          },
          {
            "group": "AI agents",
            "pages": [
              "agents/code-agent",
              "agents/conversational-agent",
              "agents/help-agent"
            ]
          },
          {
            "group": "Building blocks",
            "pages": [
              "guides/message-types",
              "guides/templates",
              "guides/flows-builder",
              "guides/secrets"
            ]
          },
          {
            "group": "Team & billing",
            "pages": [
              "guides/workspaces",
              "guides/billing"
            ]
          }
        ]
      },
      {
        "tab": "Tutorials",
        "icon": "graduation-cap",
        "groups": [
          {
            "group": "Quick start",
            "pages": [
              "quickstart",
              "whatsapp-setup"
            ]
          },
          {
            "group": "Flow templates",
            "pages": [
              "templates/overview",
              "templates/appointment-booking",
