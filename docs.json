              "templates/customer-feedback",
              "templates/support-ticket",
              "templates/survey"
            ]
          }
        ]
      },
      {
        "tab": "Tips & Tricks",
        "icon": "lightbulb",
        "groups": [
          {
            "group": "Operate your bot",
            "pages": [
              "guides/testing",
              "guides/logs",
              "guides/version-history"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "history",
        "groups": [
          {
            "group": "Release notes",
            "pages": [
              "changelog"
            ]
          }
        ]
